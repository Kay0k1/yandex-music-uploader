# ── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=tg_bot_token_here
# Telegram ID администраторов через запятую (например: 123456789,987654321)
ADMIN_IDS=your_telegram_id_here

# ── Telegram Local API (Required for >20MB uploads) ──────────────────────────
# Получить на https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# URL локального сервера (обычно http://telegram-bot-api:8081 для Docker)
TELEGRAM_API_URL=http://telegram-bot-api:8081

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=music_uploader
DB_HOST=db
DATABASE_URL=postgresql+asyncpg://postgres:change_me_strong_password@db:5432/music_uploader

# ── Security ──────────────────────────────────────────────────────────────────
# Ключ для шифрования токенов Yandex Music в базе данных.
# Сгенерировать: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВАЖНО: потеря ключа = потеря всех токенов пользователей!
ENCRYPTION_KEY=generate_and_paste_fernet_key_here

# ── Yandex OAuth ──────────────────────────────────────────────────────────────
# Опционально: переопределяет встроенные public credentials Smart TV приложения.
# Можно оставить пустым, если нет собственного приложения Yandex OAuth.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
